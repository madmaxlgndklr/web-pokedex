NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Required for password reset emails: the canonical production URL.
# Must also be added to Supabase Dashboard > Authentication > URL Configuration > Redirect URLs
# as: https://your-domain.com/auth/reset-password
# If not set, falls back to window.location.origin (breaks on Vercel preview deployments).
NEXT_PUBLIC_SITE_URL=https://web-pokedex-seven.vercel.app
